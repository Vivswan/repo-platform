# This file is managed by {{ github_username }}/repo-platform.
# Local edits may be replaced during template updates.
#
# Pulls template updates from {{ github_username }}/repo-platform's generated
# build branches: opens a PR in this repository applying `copier update` to
# this repo's channel (latest = templates/vX.Y.Z build tags, staging = the
# staging branch head).
{#- The reusable workflow lives on main, not on the build branches, so the
    uses: ref cannot be the recorded _commit verbatim: for a latest-channel
    repo the _commit is a templates/vX.Y.Z build tag whose release tag
    vX.Y.Z exists on main at the same version - strip the prefix; anything
    else (staging describe/sha strings, fresh copies) pins main. -#}
{%- set tpl_ref = _copier_answers._commit | default('', true) -%}
{%- set release_pin = tpl_ref | regex_replace('^templates/(v[0-9]+\\.[0-9]+\\.[0-9]+)$', '\\1') %}

name: Template Sync

on:
  schedule:
    - cron: "43 5 * * 1"
  workflow_dispatch:
    inputs:
      version:
        description: Template release to sync to (latest channel only; defaults to newest)
        required: false
        type: string
  workflow_call:
    inputs:
      version:
        required: false
        type: string

permissions:
  contents: write
  pull-requests: write

jobs:
  sync:
    uses: {{ github_username }}/repo-platform/.github/workflows/reusable-template-sync.yml@{% if release_pin and release_pin != tpl_ref %}{{ release_pin }}{% else %}main{% endif %}
    with:
      version: {% raw %}${{ inputs.version || '' }}{% endraw %}
    secrets:
      REPO_PLATFORM_TOKEN: {% raw %}${{ secrets.REPO_PLATFORM_TOKEN }}{% endraw %}
