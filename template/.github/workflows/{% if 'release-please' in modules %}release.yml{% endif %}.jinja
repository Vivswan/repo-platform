# Repo-owned release pipeline, called by the managed ci.yml on top of the
# all-green gate. Generated once by {{ github_username }}/repo-platform and
# never overwritten by template sync: by default it just runs the managed
# release-please machinery, and this file is where jobs BEFORE the release
# (make release-please `needs:` them) and AFTER it (gated on its outputs,
# e.g. packaging and publishing) go. Everything runs in the same workflow
# run, so it works with the default GITHUB_TOKEN too, which cannot trigger
# `on: release` workflows.

name: Release

on:
  workflow_call:

jobs:
  release-please:
    uses: ./.github/workflows/release-please.yml
    secrets: inherit

