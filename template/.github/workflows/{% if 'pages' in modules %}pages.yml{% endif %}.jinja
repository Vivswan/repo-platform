# This file is managed by {{ github_username }}/repo-platform.
# Local edits may be replaced during template updates.
#
# Deploys GitHub Pages via {{ github_username }}/repo-platform's reusable
# workflow. See its docs/pages.md for the build contract (PAGES_BASE_PATH,
# PAGES_ORIGIN, PAGES_STAGING) and the CUSTOM_DOMAIN repo variable cutover.
# One-time setup: repo Settings -> Pages -> Source: GitHub Actions.

{#- The reusable workflow lives on main, not on the build branches: strip a
    templates/vX.Y.Z build-tag _commit to the same-version release tag on
    main; anything else (staging describe/sha strings, fresh copies) pins
    main. -#}
{%- set tpl_ref = _copier_answers._commit | default('', true) -%}
{%- set release_pin = tpl_ref | regex_replace('^templates/(v[0-9]+\\.[0-9]+\\.[0-9]+)$', '\\1') -%}
{%- set uses_ref = release_pin if (release_pin and release_pin != tpl_ref) else 'main' %}
name: Pages

on:
  push:
    branches: [main]
  release:
    types: [published]
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  deploy:
    uses: {{ github_username }}/repo-platform/.github/workflows/reusable-pages.yml@{{ uses_ref }}
    with:
      setup: {{ pages_setup }}
      install_command: {{ pages_install_command | tojson }}
      build_command: {{ pages_build_command | tojson }}
      dist_dir: {{ pages_dist_dir | tojson }}
      production: {{ pages_production }}
      staging: {{ 'true' if pages_staging and pages_production == 'release' else 'false' }}
      custom_domain: {% raw %}${{ vars.CUSTOM_DOMAIN }}{% endraw %}
    permissions:
      contents: read
      pages: write
      id-token: write
