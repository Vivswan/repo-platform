# This file is managed by {{ github_username }}/repo-platform.
# Local edits may be replaced during template updates.
#
# Pulls template updates from {{ github_username }}/repo-platform: when a new
# release is available, opens a PR in this repository applying `copier update`.

name: Template Sync

on:
  schedule:
    - cron: "43 5 * * 1"
  workflow_dispatch:
    inputs:
      version:
        description: Template release to sync to (defaults to latest)
        required: false
        type: string
  workflow_call:
    inputs:
      version:
        required: false
        type: string

permissions:
  contents: write
  pull-requests: write

jobs:
  sync:
    uses: {{ github_username }}/repo-platform/.github/workflows/reusable-template-sync.yml@{{ _copier_answers._commit | default('main', true) }}
    with:
      version: {% raw %}${{ inputs.version || '' }}{% endraw %}
    secrets:
      REPO_PLATFORM_TOKEN: {% raw %}${{ secrets.REPO_PLATFORM_TOKEN }}{% endraw %}
