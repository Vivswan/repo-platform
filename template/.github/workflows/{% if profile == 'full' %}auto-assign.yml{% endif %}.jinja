# This file is managed by {{ github_username }}/repo-platform.
# Local edits may be replaced during template updates.

name: Auto Assign

on:
  workflow_dispatch:
  issues:
    types: [opened]
  pull_request:
    types: [opened, synchronize]
{% if enable_codeql %}  # Code scanning alerts have no creation trigger for Actions, so assign them
  # after each CodeQL run completes, with a weekly cron as a catch-up.
  workflow_run:
    workflows: ["CodeQL"]
    types: [completed]
  schedule:
    - cron: "23 6 * * 1"
{% endif %}
permissions:
  issues: write
  pull-requests: write
{% if enable_codeql %}  security-events: write
{% endif %}
jobs:
  auto-assign:
    uses: {{ github_username }}/repo-platform/.github/workflows/reusable-auto-assign.yml@{{ _copier_answers._commit | default('main', true) }}
