# Normalize all detected text files to LF in the repository.
* text=auto eol=lf

# Never apply text/EOL normalization to repo symlinks, so a Windows checkout
# (core.symlinks=false) can't turn them into modified regular files.
CLAUDE.md -text
.github/copilot-instructions.md -text
.github/agents.md -text
templates/agents/CLAUDE.md -text
templates/agents/.github/copilot-instructions.md -text
templates/agents/.github/agents.md -text
"template/{% if 'agents' in modules %}CLAUDE.md{% endif %}" -text
"template/.github/{% if 'agents' in modules %}copilot-instructions.md{% endif %}" -text
"template/.github/{% if 'agents' in modules %}agents.md{% endif %}" -text

# template/ is generated by scripts/compose_template.py from templates/;
# collapse it in PR diffs (CI's compose-fresh job checks it for drift).
template/** linguist-generated=true
